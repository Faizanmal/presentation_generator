# 🔐 Security Environment Variables Template

# Copy this file to .env and fill in the values

# ==========================================
# ENCRYPTION
# ==========================================

# Master encryption key (64 hex characters = 32 bytes for AES-256)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_MASTER_KEY=

# ==========================================
# SAML / SSO
# ==========================================

# Service Provider (your application) configuration
SAML_SP_ENTITY_ID=presentation-designer-saas
SAML_SP_ASSERTION_URL=https://yourdomain.com/api/auth/saml/callback

# ==========================================
# BACKUP & DISASTER RECOVERY
# ==========================================

# Backup storage directory
BACKUP_DIR=./backups

# ==========================================
# REDIS (Required for security features)
# ==========================================

REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# ==========================================
# DATABASE
# ==========================================

DATABASE_URL=postgresql://user:password@localhost:5432/presentation_designer

# ==========================================
# JWT AUTHENTICATION
# ==========================================

# JWT secret key
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=

# JWT expiration
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ==========================================
# APPLICATION
# ==========================================

APP_NAME=PresentationDesigner
APP_URL=https://yourdomain.com
NODE_ENV=production

# ==========================================
# MFA / OTP
# ==========================================

# SMS provider (Twilio, AWS SNS, etc.)
SMS_PROVIDER=twilio
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# ==========================================
# EMAIL
# ==========================================

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
EMAIL_FROM=noreply@yourdomain.com

# ==========================================
# MONITORING & LOGGING
# ==========================================

# Sentry (error tracking)
SENTRY_DSN=
SENTRY_ENABLED=true

# Log level
LOG_LEVEL=warn  # change to info/debug when troubleshooting
# set this to true to also log all Prisma queries when running at info/debug
PRISMA_LOG_QUERIES=false

# ==========================================
# SECURITY SETTINGS
# ==========================================

# Rate limiting
RATE_LIMIT_MAX_REQUESTS=100
RATE_LIMIT_WINDOW_MS=60000

# Session
SESSION_SECRET=

# CORS
CORS_ORIGIN=https://yourdomain.com

# ==========================================
# COMPLIANCE
# ==========================================

# Data retention (days)
DATA_RETENTION_DAYS=730
AUDIT_LOG_RETENTION_DAYS=2555
BACKUP_RETENTION_DAYS=90

# ==========================================
# OPTIONAL: THIRD-PARTY INTEGRATIONS
# ==========================================

# Azure AD (for SSO)
AZURE_AD_CLIENT_ID=
AZURE_AD_CLIENT_SECRET=
AZURE_AD_TENANT_ID=

# Okta (for SSO)
OKTA_DOMAIN=
OKTA_CLIENT_ID=
OKTA_CLIENT_SECRET=

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ==========================================
# NETWORK SECURITY
# ==========================================

# Allowed IP addresses (comma-separated, optional)
ALLOWED_IPS=

# Block malicious IPs automatically
AUTO_BLOCK_SUSPICIOUS_IPS=true

# ==========================================
# BACKUP CONFIGURATION
# ==========================================

# Backup schedule (cron format)
BACKUP_SCHEDULE=0 2 * * *

# Backup encryption
BACKUP_ENCRYPTION_ENABLED=true
BACKUP_ENCRYPTION_KEY=

# Cloud backup (optional)
BACKUP_CLOUD_PROVIDER=aws
AWS_S3_BUCKET=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
