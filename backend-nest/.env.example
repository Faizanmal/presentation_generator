# Database
DATABASE_URL="your-database-uri"
# optional connection pool tuning (values in milliseconds or count)
# DB_POOL_MAX=20
# DB_POOL_MIN=0
# DB_IDLE_TIMEOUT=30000
# DB_CONNECTION_TIMEOUT=0   # 0 = no timeout


# Seeding
SEED_DEFAULT_PASSWORD="Password123!"

# JWT
JWT_SECRET="your-super-secret-jwt-key-change-in-production"
JWT_EXPIRATION="7d"

# Google OAuth
GOOGLE_CLIENT_ID="your-google-client-id"
GOOGLE_CLIENT_SECRET="your-google-client-secret"
GOOGLE_CALLBACK_URL="http://localhost:3001/api/auth/google/callback"

# Queue Configuration
THINKING_QUEUE_CONCURRENCY=2
IMAGE_GENERATION_CONCURRENCY=3

# ==================== AI Provider Configuration ====================

# OpenAI (Most expensive, use as fallback)
OPENAI_API_KEY="your-openai-api-key"

# Groq (Very cheap and fast - RECOMMENDED FOR COST SAVINGS)
# Get free API key from: https://console.groq.com/
GROQ_API_KEY="your-groq-api-key"

# Google AI (Good balance between cost and quality)
# Get free API key from: https://makersuite.google.com/
GOOGLE_AI_API_KEY="your-google-ai-key"

# Ollama (Completely FREE local AI - BEST FOR COST SAVINGS)
# Run locally via Docker: docker run -d -p 11434:11434 ollama/ollama
OLLAMA_BASE_URL="http://localhost:11434"
OLLAMA_ENABLED=true

# AI Cost Optimization
AI_COST_TRACKING_ENABLED=true
AI_COST_ALERT_THRESHOLD=0.10 # Alert if single request costs more than $0.10
AI_PROVIDER_PREFERENCE="ollama,groq,google,openai" # Provider priority (cheapest first)

# Image Acquisition APIs (All Free with Registration)
# Unsplash - https://unsplash.com/developers (50 requests/hour free)
UNSPLASH_ACCESS_KEY="your-unsplash-access-key"
# Pexels - https://www.pexels.com/api/ (200 requests/hour free)
PEXELS_API_KEY="your-pexels-api-key"
# Pixabay - https://pixabay.com/api/docs/ (5,000 requests/day free)
PIXABAY_API_KEY="your-pixabay-api-key"

# Upload Directory for Acquired Images
UPLOAD_DIR="./uploads/acquired-images"

# Stripe
STRIPE_SECRET_KEY="your-stripe-secret-key"
STRIPE_WEBHOOK_SECRET="your-stripe-webhook-secret"
STRIPE_PRO_PRICE_ID="price_pro_monthly"
STRIPE_ENTERPRISE_PRICE_ID="price_enterprise_monthly"

# AWS S3
AWS_ACCESS_KEY_ID="your-aws-access-key"
AWS_SECRET_ACCESS_KEY="your-aws-secret-key"
AWS_REGION="us-east-1"
AWS_S3_BUCKET="your-s3-bucket-name"

# App
FRONTEND_URL="http://localhost:3000"
PORT=3001

# SendGrid / Email
SENDGRID_API_KEY="your-sendgrid-api-key"
MAIL_FROM="no-reply@example.com"
MAIL_FROM_NAME="Presentation Designer"

# ==================== Infrastructure Configuration ====================

# CDN Configuration
CDN_ENABLED=false
CDN_PROVIDER="local" # Options: cloudflare, cloudfront, local
CDN_BASE_URL="" # e.g., https://cdn.example.com
BASE_URL="http://localhost:3001"

# Cloudflare CDN (optional)
CLOUDFLARE_ZONE_ID=""
CLOUDFLARE_API_KEY=""
CLOUDFLARE_ACCOUNT_ID=""
CLOUDFLARE_R2_ACCESS_KEY=""
CLOUDFLARE_R2_SECRET_KEY=""

# AWS CloudFront (optional)
CLOUDFRONT_DISTRIBUTION_ID=""
CLOUDFRONT_SIGNING_KEY="" # PEM format private key
CLOUDFRONT_KEY_PAIR_ID=""
AWS_CLOUDFRONT_URL=""

# Redis Configuration (for caching & queues)
REDIS_ENABLED=false
REDIS_URL="redis://localhost:6379"

# Multi-Layer Caching (COST OPTIMIZATION)
CACHE_ENABLED=true
CACHE_KEY_PREFIX="app"
L1_CACHE_ENABLED=true # In-memory cache
L1_CACHE_MAX_SIZE=2000 # Max items in L1 cache (increased for better hit rate)
L1_CACHE_TTL=1800 # L1 cache TTL in seconds (30 minutes - increased from 5)
L2_CACHE_TTL=7200 # L2 (Redis) cache TTL in seconds (2 hours - increased from 1)

# AI Response Caching (Aggressive caching to reduce costs)
AI_CACHE_ENABLED=true
AI_CACHE_TTL=86400 # 24 hours for AI responses
AI_SEMANTIC_CACHE_ENABLED=true # Cache similar queries
AI_SEMANTIC_SIMILARITY_THRESHOLD=0.92 # High similarity threshold

# Database Sharding (Horizontal Scalability)
ENABLE_DB_SHARDING=false
DB_SHARD_STRATEGY="hash" # Options: hash, range, consistent-hash
# Shard configuration JSON (example with 3 shards)
# DB_SHARD_CONFIG='[{"id":"shard_0","url":"postgresql://...","weight":1},{"id":"shard_1","url":"postgresql://...","weight":1}]'
DB_SHARD_CONFIG='[{"id":"shard_0","url":"${DATABASE_URL}","weight":1}]'

# Queue Workers (BullMQ)
QUEUE_ENABLED=true
QUEUE_REDIS_URL="${REDIS_URL}" # Uses same Redis as caching
QUEUE_DEFAULT_CONCURRENCY=5
QUEUE_MAX_RETRIES=3

# Rate Limiting
RATE_LIMIT_ENABLED=true
RATE_LIMIT_STRATEGY="sliding-window" # Options: fixed-window, sliding-window, token-bucket, leaky-bucket
RATE_LIMIT_MAX=100 # Max requests per window
RATE_LIMIT_WINDOW=60 # Time window in seconds
RATE_LIMIT_USE_REDIS=true # Use Redis for distributed rate limiting

# Per-Endpoint Rate Limits (optional overrides)
RATE_LIMIT_AUTH_MAX=5 # Login/signup endpoints
RATE_LIMIT_AUTH_WINDOW=60
RATE_LIMIT_AI_MAX=20 # AI generation endpoints
RATE_LIMIT_AI_WINDOW=60
RATE_LIMIT_API_MAX=1000 # General API endpoints
RATE_LIMIT_API_WINDOW=60
# ==================== AI Cost Controls ====================

# Tier-Based AI Generation Limits (Daily)
FREE_TIER_AI_LIMIT_DAILY=5 # Free users: 5 generations per day
PRO_TIER_AI_LIMIT_DAILY=100 # Pro users: 100 generations per day
ENTERPRISE_AI_LIMIT_DAILY=1000 # Enterprise: 1000 generations per day

# Tier-Based Image Generation Limits (Daily)
FREE_TIER_IMAGE_LIMIT_DAILY=3 # Free users: 3 images per day
PRO_TIER_IMAGE_LIMIT_DAILY=50 # Pro users: 50 images per day
ENTERPRISE_IMAGE_LIMIT_DAILY=500 # Enterprise: 500 images per day

# Cost Thresholds and Monitoring
MAX_COST_PER_USER_PER_DAY=1.00 # Maximum $1 per user per day
MAX_COST_PER_USER_PER_MONTH=10.00 # Maximum $10 per user per month
COST_ALERT_EMAIL="" # Email for cost alerts
COST_MONITORING_ENABLED=true

# Background Processing (Cost Optimization)
AI_QUEUE_ENABLED=true # Process AI requests in background queue
AI_QUEUE_PRIORITY_DELAY=5000 # Delay non-urgent requests by 5 seconds
AI_BATCH_PROCESSING=true # Batch similar requests together

# Model Selection Strategy
AI_MODEL_SELECTION_STRATEGY="cost-optimized" # Options: cost-optimized, quality-optimized, balanced
FREE_TIER_MODEL="llama2" # Free tier uses Ollama (free)
PRO_TIER_MODEL="llama-3.3-70b-versatile" # Pro tier uses Groq (cheap)
ENTERPRISE_TIER_MODEL="gpt-4o" # Enterprise uses OpenAI (quality)

# Request Deduplication
AI_REQUEST_DEDUP_ENABLED=true # Prevent duplicate concurrent requests
AI_REQUEST_DEDUP_TTL=300 # Deduplicate identical requests within 5 minutes